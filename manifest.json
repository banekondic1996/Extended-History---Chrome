{
  "manifest_version": 2,
  "name": "Extended History | 90+ days of history",
  "version": "4.1.3",
  "default_locale": "en",
  "description": "Unlimited history retention, session management, time tracking, bookmarks, multi-device.",
  "browser_specific_settings": {
    "gecko": {
      "id": "extended-history@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "browsingData",
    "contextMenus",
    "history",
    "sessions",
    "storage",
    "tabs",
    "unlimitedStorage",
    "webNavigation"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Extended History"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
